# --- Service ---
ENVIRONMENT=local
LOG_LEVEL=INFO
AGENT_TYPE=scheduling-chat-agent

# --- Multi-tenancy (headers injected by the API gateway) ---
TENANT_HEADER=X-Tenant-ID
TRACE_ID_HEADER=X-Trace-ID
REQUIRE_TENANT=true

# --- Internal ClinicalOps API (single base URL; NOT FHIR, NOT DB) ---
INTERNAL_API_URL=http://clinicalops-api.internal
INTERNAL_TIMEOUT_SECONDS=15

# --- Vault ---
VAULT_ADDRESS=http://vault.internal:8200
VAULT_NAMESPACE=
VAULT_TIMEOUT_SECONDS=5

# --- Redis ---
REDIS_URL=redis://redis.internal:6379/0
REDIS_TIMEOUT_SECONDS=5

# --- External service (owns Google Places + key; NOT this service) ---
EXTERNAL_SERVICE_BASE_URL=http://places-api.internal
EXTERNAL_SERVICE_TIMEOUT_SECONDS=10

# --- External verification service (owns Twilio Verify + OTP state; NOT this service) ---
VERIFICATION_BASE_URL=http://verification-api.internal
VERIFICATION_TIMEOUT_SECONDS=10

# --- ADK scheduling agent (Gemini) ---
AGENT_NAME=Ava
AGENT_MODEL=gemini-2.0-flash
AGENT_MAX_OUTPUT_TOKENS=600
# Gemini credentials (source from Vault in prod; leave blank here)
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
