# --- Service ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Multi-tenancy (headers injected by the API gateway) ---
TENANT_HEADER=X-Tenant-ID
TRACE_ID_HEADER=X-Trace-ID
REQUIRE_TENANT=true

# --- Internal microservice base URLs (NOT FHIR, NOT DB) ---
INTERNAL_SCHEDULING_BASE_URL=http://scheduling-api.internal
INTERNAL_PATIENT_BASE_URL=http://patient-api.internal
INTERNAL_AVAILABILITY_BASE_URL=http://availability-api.internal
INTERNAL_TIMEOUT_SECONDS=15

# --- Vault ---
VAULT_ADDRESS=http://vault.internal:8200
VAULT_NAMESPACE=
VAULT_TIMEOUT_SECONDS=5

# --- Redis ---
REDIS_URL=redis://redis.internal:6379/0
REDIS_TIMEOUT_SECONDS=5
